# ── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=doc_tracking
DB_USER=doc_user
DB_PASSWORD=changeme

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=replace-with-a-strong-random-secret-min-32-chars
JWT_REFRESH_SECRET=replace-with-a-different-strong-random-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Redis (session / cache) ───────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── File Storage ──────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads/documents
THUMBNAIL_DIR=uploads/thumbnails
MAX_FILE_SIZE_MB=20
ALLOWED_MIME_TYPES=application/pdf,image/jpeg,image/png

# ── Email (SMTP / SendGrid) ───────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@example.com
SMTP_PASSWORD=changeme
EMAIL_FROM="Document Tracking System <noreply@example.com>"

# ── MFA (TOTP) ────────────────────────────────────────────────────────────────
MFA_ISSUER=DocTrackingSystem

# ── Encryption (AES-256-GCM) ─────────────────────────────────────────────────
ENCRYPTION_KEY=replace-with-a-32-byte-hex-encoded-key

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:4200
